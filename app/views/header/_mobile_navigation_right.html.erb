<%# app/views/layouts/_mobile_navigation_right.html.erb %>
<% if user_signed_in? %>
  <div class="flex items-center px-4">
    <div class="flex-shrink-0">
      <div class="user-avatar h-10 w-10 rounded-full bg-indigo-500 flex items-center justify-center">
        <span class="text-white text-sm font-medium">
          <%= user_avatar_initials(current_user) %>
        </span>
      </div>
    </div>
    <div class="ml-3">
      <div class="text-base font-medium text-white"><%= current_user.full_name %></div>
      <div class="text-sm font-medium text-gray-400"><%= current_user.email %></div>
    </div>
  </div>
  
  <div class="mt-3 px-2 space-y-1">
    <%= link_to profile_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700" do %>
      Profile
    <% end %>
    
    <%= link_to edit_user_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700" do %>
      Settings
    <% end %>
    
    <%= button_to destroy_user_session_path, method: :delete,
        class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-gray-700",
        data: { turbo_method: :delete } do %>
      Sign Out
    <% end %>
  </div>
<% end %>