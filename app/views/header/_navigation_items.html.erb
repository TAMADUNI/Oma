<%# app/views/layouts/_navigation_items.html.erb %>
<% navigation_items.each do |item| %>
  <% next if item[:admin] && !current_user&.admin? %>
  <% next if item[:super_admin] && !current_user&.super_admin? %>
  <% next if item[:authenticated] && !user_signed_in? %>
  <% next if item[:public] && user_signed_in? %>
  
  <% if item[:method] %>
    <%= button_to item[:name], item[:path], 
        method: item[:method],
        class: nav_link_class(item[:path]),
        data: { turbo_method: item[:method] } %>
  <% else %>
    <%= link_to item[:name], item[:path], 
        class: nav_link_class(item[:path]),
        data: { turbo_frame: item[:turbo_frame] } %>
  <% end %>
<% end %>