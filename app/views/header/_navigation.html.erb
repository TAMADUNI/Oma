<%# app/views/header/_navigation.html.erb %>
<nav class="bg-gray-900" data-controller="navigation" data-navigation-target="nav">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo and brand -->
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <%= link_to root_path, class: "flex items-center" do %>
            <%= image_tag "sicpa-logo.svg", class: "h-8 w-8", alt: "Sicpa" %>
            <span class="ml-2 text-white font-bold text-lg hidden md:block">Sicpa</span>
          <% end %>
        </div>
        
        <!-- Desktop navigation -->
        <div class="hidden md:block">
          <div class="ml-10 flex items-baseline space-x-4">
            <%= render "header/navigation_items" %>
          </div>
        </div>
      </div>
      
      <!-- Right side navigation -->
      <div class="hidden md:block">
        <div class="ml-4 flex items-center md:ml-6">
          <%= render "header/navigation_right" %>
        </div>
      </div>
      
      <!-- Mobile menu button -->
      <div class="flex md:hidden">
        <button type="button" 
                data-action="click->navigation#toggleMenu"
                class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-800 focus:ring-white"
                aria-controls="mobile-menu" 
                aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile menu -->
  <div class="hidden md:hidden" id="mobile-menu" data-navigation-target="mobileMenu">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <%= render "header/mobile_navigation_items" %>
    </div>
    <div class="pt-4 pb-3 border-t border-gray-700">
      <%= render "header/mobile_navigation_right" %>
    </div>
  </div>
</nav>