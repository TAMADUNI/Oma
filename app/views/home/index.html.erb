<%# app/views/home/index.html.erb %>
<div class="bg-white">
  <!-- Hero section -->
  <div class="relative bg-gray-900 overflow-hidden">
    <div class="absolute inset-0">
      <%= image_tag "sicpa-hero.webp", class: "w-full h-full object-cover", alt: "Sicpa Hero" %>
      <div class="absolute inset-0 bg-gray-900 bg-opacity-75"></div>
    </div>
    <div class="relative max-w-7xl mx-auto py-24 px-4 sm:py-32 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Welcome to Sicpa
      </h1>
      <p class="mt-6 text-xl text-gray-300 max-w-3xl">
        Secure authentication and identity management for the modern enterprise. 
        Protect your digital assets with our cutting-edge solutions.
      </p>
      <div class="mt-10 flex space-x-4">
        <%= link_to "Get Started", new_user_registration_path, 
            class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
        <%= link_to "Learn More", about_path, 
            class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-indigo-100 bg-indigo-800 bg-opacity-50 hover:bg-opacity-70" %>
      </div>
    </div>
  </div>

  <!-- Features section -->
  <div class="py-16 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-base font-semibold text-indigo-600 tracking-wide uppercase">Features</h2>
        <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
          Enterprise-grade authentication
        </p>
        <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
          Everything you need to secure your application with modern authentication standards.
        </p>
      </div>

      <div class="mt-16">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          <!-- Feature 1 -->
          <div class="relative">
            <div class="absolute flex items-center justify-center h-12 w-12 rounded-md bg-indigo-500 text-white">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <div class="ml-16">
              <h3 class="text-lg font-medium text-gray-900">Secure Authentication</h3>
              <p class="mt-2 text-base text-gray-500">
                Multi-factor authentication, password policies, and session management to keep your data safe.
              </p>
            </div>
          </div>

          <!-- Feature 2 -->
          <div class="relative">
            <div class="absolute flex items-center justify-center h-12 w-12 rounded-md bg-indigo-500 text-white">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div class="ml-16">
              <h3 class="text-lg font-medium text-gray-900">Role-Based Access</h3>
              <p class="mt-2 text-base text-gray-500">
                Granular permissions and role management for users, admins, and super administrators.
              </p>
            </div>
          </div>

          <!-- Feature 3 -->
          <div class="relative">
            <div class="absolute flex items-center justify-center h-12 w-12 rounded-md bg-indigo-500 text-white">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div class="ml-16">
              <h3 class="text-lg font-medium text-gray-900">Real-time Updates</h3>
              <p class="mt-2 text-base text-gray-500">
                Hotwire-powered real-time notifications and live updates for better user experience.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="bg-indigo-700">
    <div class="max-w-2xl mx-auto text-center py-16 px-4 sm:py-20 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        <span class="block">Ready to get started?</span>
        <span class="block">Join Sicpa today.</span>
      </h2>
      <p class="mt-4 text-lg leading-6 text-indigo-200">
        Sign up now and experience the most secure authentication system for your business.
      </p>
      <%= link_to "Create Free Account", new_user_registration_path,
          class: "mt-8 w-full inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-indigo-600 bg-white hover:bg-indigo-50 sm:w-auto" %>
    </div>
  </div>
</div>